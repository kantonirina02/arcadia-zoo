{
  "functions": {
    "server.js": {
      "includeFiles": ["{src,assets,pages}/**", "index.html"]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://arcadia-zoo.fly.dev/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/server.js"
    }
  ]
}
